# Copy to secrets.enc.yaml, fill in real values, then encrypt with SOPS
# using the repo's existing age recipient:
#
#   cp secrets.enc.yaml.example secrets.enc.yaml
#   $EDITOR secrets.enc.yaml         # paste real values
#   sops -e -i secrets.enc.yaml      # encrypt in place
#
# The .sops.yaml at the repo root has a creation_rule matching
# `opentofu/.*\.enc\.yaml$` to the same age recipient as the Flux
# secrets — no extra config needed before `sops -e`. After the first
# encryption the file will look very different (encrypted MAC, sops:
# metadata block, etc.) but the key names below remain readable.

# Proxmox API token in the form: <user>@<realm>!<token-id>=<secret>
# Generate via Proxmox UI → Datacenter → API Tokens. Create a dedicated
# `tofu@pve` user with role "PVEVMAdmin" + "Datastore.AllocateTemplate"
# + "Sys.Audit" + "Sys.Modify" (see opentofu/README.md for the exact CLI
# recipe).
proxmox_api_token: "tofu@pve!opentofu=00000000-0000-0000-0000-000000000000"

# Tailscale auth key, reusable + ephemeral + pre-approved, tagged
# tag:k8s-node. Generate at https://login.tailscale.com/admin/settings/keys
tailscale_authkey: "tskey-auth-XXXXXXXXXXXXXXXXXX"
