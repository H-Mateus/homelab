# Tailnet domain (without the leading host part). Find via
# `tailscale status` on any device; looks like `tail0000.ts.net`.
TS_TAILNET=tail0000

# Reusable + ephemeral + pre-approved auth key tagged tag:garage.
# Generate at https://login.tailscale.com/admin/settings/keys after
# adding tag:garage to your tagOwners (see README → Bootstrap step 0).
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXXX

# Bind-mount paths on the TrueNAS host. All inside the dedicated
# `HDDs/garage` ZFS dataset (see README → Bootstrap step 1). Pre-create
# and `chown 568:568`.
GARAGE_META_DIR=/mnt/HDDs/garage/meta
GARAGE_DATA_DIR=/mnt/HDDs/garage/data
GARAGE_TS_STATE_DIR=/mnt/HDDs/garage/ts-state

# Path to a host-side file containing only the inter-node RPC secret
# (a 32-byte hex string). Generated once in bootstrap step 2.
GARAGE_RPC_SECRET_FILE=/mnt/HDDs/garage/rpc_secret
