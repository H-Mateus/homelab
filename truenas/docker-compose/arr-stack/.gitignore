# truenas/docker-compose/prowlarr/.gitignore
# Everything in configs/ is runtime state with secrets baked in.
# Backups happen at the filesystem level (TrueNAS snapshots), not via git.
configs/*


# Just so the directory exists in the repo
!configs/.gitkeep
!configs/qbit/
configs/qbit/*
!configs/qbit/wireguard
configs/qbit/wireguard/*
!configs/qbit/wireguard/wg0.conf.example

# Tailscale sidecar node state, if ever created relative to the stack dir
# (normally lives in the CONFIG_PATH dataset). Contains device private keys.
ts-state/

# Local env
.env

# Scratch file of service API keys collected during setup — never commit.
apikeys.txt
