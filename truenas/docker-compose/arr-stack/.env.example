# truenas/docker-compose/arr-stack/.env.example

# Absolute path to the SINGLE media dataset on the host (e.g. /mnt/tank/media).
# Mounted as /media into every *arr, Jellyfin, and qBittorrent. Downloads and
# the organized library MUST live as subdirectories of this one dataset
# (downloads/, movies/, tv/, music/) so Radarr/Sonarr can hardlink instead of
# copy. See README "Storage layout". Set recordsize=1M, atime=off, owner 568.
MEDIA_PATH=/mnt/tank/media

# Absolute path to the app config/database dataset on the fast (SSD) pool
# (e.g. /mnt/apps/arr-stack). Holds each service's /config (SQLite DBs, Jellyfin
# metadata, qBittorrent + WireGuard) and the Tailscale sidecar node state under
# ts-state/. Kept on SSD and separate from bulk media so it can be snapshotted /
# rolled back / backed up on its own schedule. Create with the TrueNAS "Apps"
# preset, owned by uid/gid 568.
CONFIG_PATH=/mnt/apps/arr-stack

# LAN subnet allowed to reach qBittorrent's WebUI through the VPN killswitch.
# Should match your home LAN, e.g. 192.168.0.0/24 or 192.168.1.0/24.
LAN_IP_RANGE=x.x.x.x/x

# Tailscale auth keys — one reusable, pre-approved key per sidecar. Each
# sidecar registers a separate Tailnet device, reachable at
# https://<service>.<your-tailnet>.ts.net. Generate in the Tailscale
# admin console with the tag you've authorised in your ACLs.
TS_AUTHKEY_JELLYFIN=tskey-auth-REPLACE_ME
TS_AUTHKEY_RADARR=tskey-auth-REPLACE_ME
TS_AUTHKEY_SONARR=tskey-auth-REPLACE_ME
TS_AUTHKEY_LIDARR=tskey-auth-REPLACE_ME
TS_AUTHKEY_BAZARR=tskey-auth-REPLACE_ME
TS_AUTHKEY_PROWLARR=tskey-auth-REPLACE_ME
TS_AUTHKEY_SEERR=tskey-auth-REPLACE_ME
TS_AUTHKEY_PROFILARR=tskey-auth-REPLACE_ME
