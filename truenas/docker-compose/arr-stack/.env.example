# truenas/docker-compose/prowlarr/.env.example

# Path to the media library on the TrueNAS host.
# Mounted into each *arr and Jellyfin as /media.
MEDIA_PATH=/path/to/media/dataset

# LAN subnet allowed to reach qBittorrent's WebUI through the VPN killswitch.
# Should match your home LAN, e.g. 192.168.0.0/24 or 192.168.1.0/24.
LAN_IP_RANGE=x.x.x.x/x
