# You can find documentation for all the supported env variables at
# https://docs.immich.app/install/environment-variables

# The location where your uploaded files are stored. Points at the same
# dataset the TrueNAS Immich app was using, so the new stack inherits all
# existing media.
UPLOAD_LOCATION=/mnt/HDDs/immich/data

# The location where your database files are stored. Must NOT be on an NFS
# share. We reuse the existing pgData directory from the TrueNAS Immich app
# (currently Postgres 18 + vectorchord 0.5.3 — see docker-compose.yml for
# version-pin notes).
DB_DATA_LOCATION=/mnt/HDDs/immich/pgData

# Optional: set a timezone, e.g. Europe/London.
TZ=Europe/London

IMMICH_VERSION=v2

# Postgres connection secret. Must match whatever was set in the TrueNAS app
# config when the existing pgData dir was initialised — if you change this
# without re-init'ing the DB, immich-server can't authenticate to its own DB.
# Use only [A-Za-z0-9] — no special characters or spaces.
DB_PASSWORD=postgres

# Tailscale auth key (reusable, ephemeral, pre-approved, tagged with the
# tag you authorised in your ACLs). Used by the immich-family-ts sidecar
# to register this stack as its own Tailnet device.
TS_AUTHKEY=tskey-auth-REPLACE_ME

# The values below this line do not need to be changed unless you set
# something different on the TrueNAS Immich app originally.
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
