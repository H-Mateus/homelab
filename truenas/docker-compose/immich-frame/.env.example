# truenas/docker-compose/immich-frame/.env.example

# URL to immich server
IMMICH_URL=http://immich.com

# Immich API key, setup info here: https://immichframe.dev/docs/getting-started/configuration#api-key-permissions
IMMICH_API_KEY=xxxx

# Tailscale authkey to spin up service as it's own device
TS_AUTHKEY=xxxx

# OpenWeatherMap API key: https://immichframe.dev/docs/getting-started/configuration#weather
WEATHER_API_KEY=xxxx
