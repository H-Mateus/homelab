# truenas/docker-compose/immich-frame/.env.example

# URL to the Immich server. ImmichFrame reaches it east-west over the shared
# `immich_default` Docker network (both stacks run on the same local host), so
# use the Compose service name + native port — NOT a tailnet/public URL.
IMMICH_URL=http://immich-server:2283

# Immich API key, setup info here: https://immichframe.dev/docs/getting-started/configuration#api-key-permissions
# The migrated Immich inherited the old pgData, so an API key created on the
# remote instance should still be valid here.
IMMICH_API_KEY=xxxx

# Tailscale authkey to spin up service as it's own device
TS_AUTHKEY=xxxx

# OpenWeatherMap API key: https://immichframe.dev/docs/getting-started/configuration#weather
WEATHER_API_KEY=xxxx
