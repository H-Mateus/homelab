# truenas/docker-compose/dockhand-ts/.env.example

# Upstream Dockhand address as seen from this container: the TrueNAS box's LAN
# IP and Dockhand's published port. Kept out of git because the LAN IP is
# environment-specific. TrueNAS apps get a high node-port (30000-32767) rather
# than the native port — confirm it under the app's Ports panel (e.g. 30328).
DOCKHAND_UPSTREAM=192.168.x.x:30328

# Tailscale auth key for the Dockhand sidecar device. Use a reusable,
# pre-approved key carrying a tag you've authorised in your ACLs. Generate in
# the Tailscale admin console. Registers as dockhand.<tailnet>.ts.net.
TS_AUTHKEY_DOCKHAND=tskey-auth-REPLACE_ME
