# MinIO root creds. Treat as emergency-break-glass — create a scoped user
# for OpenTofu (see README) and use those credentials day-to-day.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=replace-with-a-long-random-string

# Tailnet domain (without the leading `minio.` host part). Find via
# `tailscale status` on any device; looks like `tail1234.ts.net`.
TS_TAILNET=tail0000

# Reusable + ephemeral + pre-approved auth key tagged tag:minio. Generate
# at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXXX

# Bind-mount paths on the TrueNAS host. These should be subdirectories
# inside a dedicated `minio` ZFS dataset (see README → Bootstrap step 1).
# Pre-create with `mkdir -p` and `chown 568:568`.
MINIO_DATA_DIR=/mnt/HDDs/minio/data
MINIO_TS_STATE_DIR=/mnt/HDDs/minio/ts-state
