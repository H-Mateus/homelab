# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.

# ----------------------------
# Common settings
# ----------------------------

PUID=1000
PGID=1000

TZ=Europe/London

DOMAIN=example.com

APPDATA_DIR=/mnt/tank/docker/appdata

# ----------------------------
# Vaultwarden
# ----------------------------

# Set to true only during initial setup, then disable
VW_SIGNUPS_ALLOWED=false

# Generate a secure admin token: openssl rand -base64 48
VW_ADMIN_TOKEN=your_vaultwarden_admin_token

# ----------------------------
# Nextcloud – PostgreSQL database
# ----------------------------

NC_DB_NAME=nextcloud
NC_DB_USER=nextcloud

# Use a strong, randomly generated password
NC_DB_PASSWORD=your_nextcloud_db_password

# ----------------------------
# Nextcloud – admin user
# ----------------------------

NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=your_nextcloud_admin_password

# ----------------------------
# Nextcloud – data directory
# (separate dataset recommended for large file libraries)
# ----------------------------

NC_DATA_DIR=/mnt/tank/nextcloud
