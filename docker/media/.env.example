# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.

# ----------------------------
# Common settings
# ----------------------------

# User/group IDs that containers run as (use `id` in your shell to find these)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/London

# Base domain for Traefik routing (e.g. example.com)
DOMAIN=example.com

# ----------------------------
# Paths
# ----------------------------

# Root directory for container config/data (e.g. /mnt/tank/docker/appdata)
APPDATA_DIR=/mnt/tank/docker/appdata

# Media library root (should contain movies/, tv/, music/ sub-directories)
MEDIA_DIR=/mnt/tank/media

# Download directory (should contain complete/ and incomplete/ sub-directories)
DOWNLOADS_DIR=/mnt/tank/downloads

# ----------------------------
# VPN (Gluetun) – for qBittorrent
# ----------------------------

# VPN provider name (see https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers)
VPN_PROVIDER=mullvad

# VPN type: openvpn or wireguard
VPN_TYPE=openvpn

VPN_USER=your_vpn_username
VPN_PASSWORD=your_vpn_password

# Comma-separated list of countries to connect through (provider-dependent)
VPN_COUNTRIES=Netherlands
