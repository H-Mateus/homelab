# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.

# ----------------------------
# Common settings
# ----------------------------

PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/London

# Base domain (e.g. example.com)
DOMAIN=example.com

# Root directory for container config/data
APPDATA_DIR=/mnt/tank/docker/appdata

# ----------------------------
# Cloudflare
# ----------------------------

# Cloudflare API token with Zone:DNS:Edit permissions
# Create at https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=your_cloudflare_api_token

# ----------------------------
# Traefik dashboard basic auth
# ----------------------------

# Generate with: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$your_hashed_password_here
